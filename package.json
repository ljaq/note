{
  "name": "note",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf docs out && next build && mv out docs",
    "start": "next start",
    "commit": "git add . && cz",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:ascii-frames": "node scripts/generate-ascii-frames.mjs",
    "migrate:ascii-frames": "node scripts/migrate-ascii-frames-to-processed.mjs"
  },
  "config": {
    "commitizen": {
      "path": "cz-git",
      "czConfig": "./commitlint.config.js"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@mdx-js/react": "^3.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "lucide-react": "^1.7.0",
    "next": "16.0.10",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
